{
    "manifest_version": 3,
    "name": "Backlink Gap Analyzer",
    "version": "2.0.0",
    "description": "分析竞争对手外链差异，发现全类型外链机会，半自动发布评论",
    "permissions": [
        "activeTab",
        "tabs",
        "storage",
        "scripting",
        "identity",
        "alarms",
        "sidePanel",
        "unlimitedStorage"
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "action": {
        "default_title": "Open Backlink Analyzer"
    },
    "side_panel": {
        "default_path": "popup/popup.html"
    },
    "background": {
        "service_worker": "background/background.js"
    },
    "oauth2": {
        "client_id": "YOUR_GOOGLE_OAUTH2_CLIENT_ID.apps.googleusercontent.com",
        "scopes": ["https://www.googleapis.com/auth/spreadsheets"]
    },
    "web_accessible_resources": [
        {
            "resources": [
                "content/comment-publisher.css",
                "data/gefei-226-resources.json"
            ],
            "matches": [
                "<all_urls>"
            ]
        }
    ]
}
